# Coverage configuration for the Python checker (scripts/coverage_check.py).
# Used by the `coverage-checker-tests` CI job and locally. The CI command
# (and this local usage example) are rcfile-driven so the 100% gate below
# applies — never pass `--fail-under` on the CLI, which would override the
# rcfile and silently lower the bar:
#   python3 -m coverage run --rcfile=scripts/tests/.coveragerc \
#       -m unittest discover -s scripts/tests
#   python3 -m coverage report --rcfile=scripts/tests/.coveragerc
[run]
branch = true
# Only the checker itself is gated; the test file is the harness.
include = */coverage_check.py

[report]
# The `if __name__ == "__main__":` shim only runs when the script is invoked
# as a process (it is, in CI; tests call main(argv) directly). Excluding the
# guard line is the standard coverage.py idiom and is not an inline source
# suppression.
exclude_also =
    if __name__ == .__main__.:
show_missing = true
# 100%, not 95%: the checker is security/validation/trust-boundary code in
# its entirety, so the policy's 100% trust-boundary rule applies to it — not
# the 95% delta rule that covers ordinary new code.
fail_under = 100
